# ===== Neo4j 图数据库配置 =====
# 如果不配置这些变量，系统将使用本地 JSON 文件存储图数据

# Neo4j 连接 URI (例如: bolt://localhost:7687)
# NEO4J_URI=bolt://localhost:7687

# Neo4j 用户名
# NEO4J_USER=neo4j

# Neo4j 密码
# NEO4J_PASSWORD=your_password

# ===== 图数据存储配置 =====

# JSON 文件存储路径 (当 Neo4j 未配置时使用)
# GRAPH_JSON_PATH=./data/graph-data.json

# 启用 Mock 模式 (内存存储，用于开发测试)
# GRAPH_MOCK_MODE=false

# ===== Gemini AI 配置 =====
# 用于智能检索和知识抽取

# GEMINI_API_KEY=your_gemini_api_key
